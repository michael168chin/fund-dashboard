// --- 工具函數 ---
const safeParseNumber = (str) => {
  if (!str) return 0;
  const cleanStr = String(str).replace(/,/g, '').replace(/"/g, '').trim();
  const num = Number(cleanStr);
  return isNaN(num) ? 0 : num;
};

const formatNumber = (num) => num ? Math.round(num).toLocaleString() : '0';

// 自動從日期字串產生 "M/D 截單" 標籤
const getDeadlineLabel = (dateStr) => {
  try {
    const date = new Date(dateStr.replace(/-/g, "/"));
    if (isNaN(date.getTime())) return "截單日未定";
    return `${date.getMonth() + 1}/${date.getDate()} 截單`;
  } catch (e) {
    return "1/23 截單";
  }
};

