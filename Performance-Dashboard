                mainTitle: "2026 開門紅", 
                subTitle: "王者歸來 開創新局", 
                deadlineDate: DEFAULT_DEADLINE
            }
        };
        return saved ? { ...defaultData, ...JSON.parse(saved) } : defaultData;
    }
    return { targets: BASE_TARGETS, current: {}, ranks: {}, sheetUrl: DEFAULT_SHEET_URL, texts: {} };
  });

  const [isModalOpen, setIsModalOpen] = useState(false);
  const [isSyncing, setIsSyncing] = useState(false);

  useEffect(() => {
    if (!data.sheetUrl) return;
    const fetchData = async () => {
      setIsSyncing(true);
      try {
        const res = await fetch(`${data.sheetUrl}${data.sheetUrl.includes('?')?'&':'?'}t=${Date.now()}`);
        const text = await res.text();
        const rows = text.split(/\r\n|\n|\r/);
        
        // 解析邏輯 (Row 1 Header, Row 2 Target, Row 3 Current)
        const getRowData = (idx) => {
            if (rows.length <= idx) return [];
            return rows[idx].match(/(".*?"|[^",]+)(?=\s*,|\s*$)/g) || [];
        };

        const targets = getRowData(1); // Row 2
        const currents = getRowData(2); // Row 3
        
        // G 欄位設定 (Index 6) - 因為 A欄是說明欄，所以 G 欄是 index 6
        const getColG = (idx) => {
            const row = getRowData(idx);
            return row.length > 6 ? row[6].replace(/"/g, '').trim() : '';
        };

        if (targets.length >= 6 && currents.length >= 6) {
            const newData = {
              ...data,
              targets: {
                  fyfc: safeParseNumber(targets[1]), // B
                  anp: safeParseNumber(targets[2]), // C
                  cases: safeParseNumber(targets[3]), // D
                  active: safeParseNumber(targets[4]), // E
                  recruit: safeParseNumber(targets[5]), // F
              },
              current: {
                  fyfc: safeParseNumber(currents[1]),
                  anp: safeParseNumber(currents[2]),
                  cases: safeParseNumber(currents[3]),
                  active: safeParseNumber(currents[4]),
                  recruit: safeParseNumber(currents[5]),
              },
              ranks: {
                  fyfc: [getRowData(3)[1], getRowData(4)[1], getRowData(5)[1]].map(s=>s?.replace(/"/g,'')).filter(Boolean),
                  anp: [getRowData(3)[2], getRowData(4)[2], getRowData(5)[2]].map(s=>s?.replace(/"/g,'')).filter(Boolean),
                  cases: [getRowData(3)[3], getRowData(4)[3], getRowData(5)[3]].map(s=>s?.replace(/"/g,'')).filter(Boolean),
                  active: [getRowData(3)[4], getRowData(4)[4], getRowData(5)[4]].map(s=>s?.replace(/"/g,'')).filter(Boolean),
                  recruit: [getRowData(3)[5], getRowData(4)[5], getRowData(5)[5]].map(s=>s?.replace(/"/g,'')).filter(Boolean),
              },
              texts: {
                  mainTitle: getColG(1) || data.texts.mainTitle,
                  subTitle: getColG(2) || data.texts.subTitle,
                  trophyTitle: getColG(3) || data.texts.trophyTitle,
                  trophySub: getColG(4) || data.texts.trophySub,
                  deadlineDate: getColG(5) || data.texts.deadlineDate,
              }
            };
            
            if (JSON.stringify(newData) !== JSON.stringify(data)) {
              setData(newData);
              localStorage.setItem(STORAGE_KEY, JSON.stringify(newData));
            }
        }
      } catch (e) { console.error("Sync Error", e); } finally { setIsSyncing(false); }
    };
    fetchData();
    const interval = setInterval(fetchData, 30000);
    return () => clearInterval(interval);
  }, [data.sheetUrl, data]);

  const handleUpdate = (newData) => { setData(newData); localStorage.setItem(STORAGE_KEY, JSON.stringify(newData)); };

  const deadlineLabel = getDeadlineLabel(data.texts?.deadlineDate || DEFAULT_DEADLINE);

  return (
    <div className="relative h-[100dvh] w-screen bg-black flex flex-col font-sans overflow-hidden">
      <CustomStyles />
      <div className="absolute inset-0 bg-gradient-to-b from-red-900 via-black to-black opacity-80 z-0"></div>
      <div className="absolute inset-0 z-0 opacity-30" style={{backgroundImage: 'radial-gradient(circle, #fbbf24 1px, transparent 1px)', backgroundSize: '30px 30px'}}></div>
      <div className="absolute inset-0 z-0 overflow-hidden pointer-events-none">{[...Array(12)].map((_, i) => (<div key={i} className="absolute text-yellow-500 opacity-0 animate-coin" style={{left: `${Math.random() * 100}%`, animationDuration: `${Math.random() * 5 + 5}s`, animationDelay: `${Math.random() * 5}s`, fontSize: `${Math.random() * 20 + 10}px`}}>{['💰','✨','🧧'][Math.floor(Math.random()*3)]}</div>))}</div>

      <header className="flex-none relative z-10 p-3 flex flex-row items-center justify-between border-b border-white/10 bg-black/40 backdrop-blur-md">
        <div className="flex items-center w-1/3 justify-start"><AllianzLogo /><h2 className="ml-2 text-lg lg:text-2xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-yellow-200 to-yellow-500 whitespace-nowrap hidden sm:block">A321 宏國通訊處</h2>{isSyncing && <RefreshCw className="w-3 h-3 text-green-400 animate-spin ml-2" />}</div>
        <div className="text-center w-1/3">
            <h1 className="text-2xl lg:text-5xl font-black text-transparent bg-clip-text bg-gradient-to-b from-yellow-300 via-red-500 to-red-700 drop-shadow-[0_2px_4px_rgba(220,38,38,0.5)] tracking-widest whitespace-nowrap">{data.texts.mainTitle}</h1>
            <p className="text-yellow-200/80 text-[10px] lg:text-sm tracking-[0.3em] mt-0.5">{data.texts.subTitle}</p>
        </div>
        <div className="w-1/3 flex justify-end">
            <div className="flex items-center bg-red-600 text-white px-2 py-1 lg:px-4 lg:py-2 rounded-full shadow-lg animate-pulse">
                <AlertCircle className="w-4 h-4 mr-1 lg:mr-2" />
                <span className="font-bold whitespace-nowrap text-xs lg:text-sm">{deadlineLabel}</span>
            </div>
        </div>
      </header>

      <main className="flex-1 min-h-0 relative z-10 p-3 lg:p-6 flex flex-col lg:flex-row gap-4 items-center justify-center">
        <div className="w-full lg:w-4/12 h-1/4 lg:h-full flex flex-col items-center justify-center lg:justify-center">
          <div className="relative transform scale-75 lg:scale-110 mb-2 lg:mb-8"><CustomTrophy title={data.texts.trophyTitle} subTitle={data.texts.trophySub} /></div>
          <div className="hidden lg:block bg-gradient-to-r from-red-900/80 to-black/80 p-4 rounded-2xl border border-yellow-500/30 text-center w-full max-w-sm backdrop-blur-sm shadow-lg"><h3 className="text-xl font-bold text-yellow-400 mb-1 flex items-center justify-center"><Trophy className="mr-2" /> {data.texts.trophyTitle}</h3><div className="text-sm text-gray-300">目標鎖定 120% 超額達成</div></div>
        </div>

        <div className="w-full lg:w-8/12 h-3/4 lg:h-full flex flex-col space-y-2 lg:space-y-4">
          <div className="flex-none"><CountdownTimer targetDateStr={data.texts.deadlineDate} /></div>
          <div className="flex-1 min-h-0 grid grid-cols-2 lg:grid-cols-6 gap-2 lg:gap-4 overflow-y-auto lg:overflow-visible pb-20 lg:pb-0">
            <div className="lg:col-span-2"><MetricCard title="FYFC" current={data.current.fyfc} baseGoal={data.targets.fyfc} icon={TrendingUp} colorClass="text-red-400" unit="" ranks={data.ranks.fyfc} /></div>
            <div className="lg:col-span-2"><MetricCard title="ANP" current={data.current.anp} baseGoal={data.targets.anp} icon={Banknote} colorClass="text-green-400" unit="" ranks={data.ranks.anp} /></div>
            <div className="col-span-2 lg:col-span-2"><MetricCard title="新契約件數" current={data.current.cases} baseGoal={data.targets.cases} icon={FileText} colorClass="text-purple-400" unit="件" ranks={data.ranks.cases} /></div>
            <div className="lg:col-span-3"><MetricCard title="實動人數" current={data.current.active} baseGoal={data.targets.active} icon={Users} colorClass="text-yellow-400" unit="人" ranks={data.ranks.active} /></div>
            <div className="lg:col-span-3"><MetricCard title="新聘人數" current={data.current.recruit} baseGoal={data.targets.recruit} icon={UserPlus} colorClass="text-blue-400" unit="人" ranks={data.ranks.recruit} /></div>
          </div>
        </div>
      </main>

      <footer className="flex-none relative z-10 text-center p-2 text-gray-500 text-[10px] border-t border-white/5">Powered by A321 宏國通訊處</footer>
      <button onClick={() => setIsModalOpen(true)} className="fixed bottom-12 right-4 z-50 p-2 bg-gray-800/80 hover:bg-gray-700 text-white rounded-full border border-gray-600 shadow-lg transition-all group backdrop-blur-sm"><Settings className="w-5 h-5 group-hover:rotate-90 transition-transform duration-500" /></button>
      <SettingsModal isOpen={isModalOpen} onClose={() => setIsModalOpen(false)} data={data} onUpdate={handleUpdate} />
    </div>
  );
}
