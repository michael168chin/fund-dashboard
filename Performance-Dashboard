// --- 組件：設定視窗 ---
const SettingsModal = ({ isOpen, onClose, data, onUpdate }) => {
  const [isAuthenticated, setIsAuthenticated] = useState(false);
  const [passwordInput, setPasswordInput] = useState('');
  const [formData, setFormData] = useState(data);
  const [isTestLoading, setIsTestLoading] = useState(false);
  const [testResult, setTestResult] = useState(null);
  const [loginError, setLoginError] = useState(false);

  useEffect(() => {
    if (isOpen) {
      setFormData(data);
      setIsAuthenticated(false);
      setPasswordInput('');
      setTestResult(null);
      setLoginError(false);
    }
  }, [isOpen, data]);

  const handleUnlock = (e) => {
    e.preventDefault();
    if (passwordInput === ADMIN_PASSWORD) {
      setIsAuthenticated(true);
      setPasswordInput('');
      setLoginError(false);
    } else {
      setLoginError(true);
      setTimeout(() => setLoginError(false), 500);
      setPasswordInput('');
    }
  };

  const handleSave = () => { onUpdate(formData); onClose(); };
  const handleChange = (e) => { const { name, value } = e.target; setFormData(prev => ({ ...prev, [name]: name === 'sheetUrl' ? value : Number(value) })); };

  const testConnection = async () => {
    if (!formData.sheetUrl) return;
    setIsTestLoading(true);
    setTestResult({ status: 'loading', msg: '讀取中...' });
    try {
      const res = await fetch(`${formData.sheetUrl}${formData.sheetUrl.includes('?')?'&':'?'}t=${Date.now()}`);
      if (!res.ok) throw new Error("無法讀取 URL");
      const text = await res.text();
      const rows = text.split(/\r\n|\n|\r/);
      // 至少要有 3 行資料
      if (rows.length < 3) throw new Error("CSV 行數不足");
      
      // 從第二行開始讀取 (Row 2, B欄開始)
      const values = rows[1].match(/(".*?"|[^",]+)(?=\s*,|\s*$)/g);
      
      // 注意：現在是從第二欄(Index 1)開始，所以長度至少要 >= 6
      if (values && values.length >= 6) {
         setTestResult({ 
             status: 'success', 
             msg: `讀取成功! FYFC:${values[1]}, ANP:${values[2]}...` 
         });
      } else {
         throw new Error("欄位不足 (需6欄)");
      }
    } catch (e) {
      setTestResult({ status: 'error', msg: '錯誤: ' + e.message });
    } finally {
      setIsTestLoading(false);
    }
  };

  const isSheetLinked = formData.sheetUrl && formData.sheetUrl.length > 0;
  if (!isOpen) return null;

  return (
    <div className="fixed inset-0 z-50 flex items-center justify-center bg-black/90 backdrop-blur-sm p-4">
      <div className="bg-slate-900 border border-red-500/50 w-full max-w-lg rounded-2xl shadow-2xl overflow-hidden flex flex-col max-h-[90vh]">
        <div className="p-4 pb-2 flex-none border-b border-white/10 relative">
            <button onClick={onClose} className="absolute top-4 right-4 text-gray-400 hover:text-white z-10"><X className="w-6 h-6" /></button>
            <h3 className="text-xl font-bold text-white flex items-center"><Settings className="w-5 h-5 mr-2 text-red-400" />{isAuthenticated ? '設定數據來源' : '管理員驗證'}</h3>
        </div>
        <div className="p-4 pt-4 flex-1 overflow-y-auto">
          {!isAuthenticated ? (
            <form onSubmit={handleUnlock} className="space-y-6">
                <div className="text-center p-4 bg-red-900/20 rounded-xl border border-red-500/30"><Lock className="w-10 h-10 text-red-400 mx-auto mb-2" /><p className="text-red-200 text-sm">請輸入管理密碼以解鎖設定</p></div>
                <div className={loginError ? 'animate-shake' : ''}><input type="password" value={passwordInput} onChange={e => setPasswordInput(e.target.value)} className={`w-full bg-slate-800 border rounded px-4 py-3 text-center text-white outline-none text-lg tracking-widest transition-colors ${loginError ? 'border-red-500' : 'border-slate-600 focus:border-red-500'}`} placeholder="輸入密碼" autoFocus /></div>
                <button type="submit" className="w-full bg-red-600 hover:bg-red-500 text-white font-bold py-3 rounded-xl shadow-lg transition-transform active:scale-95">解鎖</button>
            </form>
          ) : (
            <div className="space-y-4">
                <div className="bg-green-900/20 p-3 rounded-xl border border-green-500/30">
                    <div className="flex items-center text-green-400 font-bold mb-2"><FileSpreadsheet className="w-4 h-4 mr-2"/> Google Sheet 連動</div>
                    <div className="text-xs text-gray-300 mb-2">連結 CSV (預設連結已填入):</div>
                    <input type="text" name="sheetUrl" value={formData.sheetUrl || ''} onChange={handleChange} placeholder="https://..." className="w-full bg-slate-800 border border-slate-600 rounded p-2 text-sm text-gray-300 focus:border-green-500 outline-none"/>
                    <div className="mt-2 flex justify-between items-center"><button type="button" onClick={testConnection} className="text-xs bg-green-700 hover:bg-green-600 px-3 py-1 rounded text-white disabled:opacity-50" disabled={!formData.sheetUrl}>{isTestLoading ? <RefreshCw className="w-3 h-3 animate-spin inline mr-1"/> : <LinkIcon className="w-3 h-3 inline mr-1"/>}測試</button>{testResult && <span className={`text-xs ${testResult.status === 'error' ? 'text-red-400' : 'text-green-400'} flex items-center truncate ml-2`} title={testResult.msg}>{testResult.status === 'success' ? <CheckCircle className="w-3 h-3 mr-1"/> : <AlertTriangle className="w-3 h-3 mr-1"/>}{testResult.msg}</span>}</div>
                </div>
            </div>
          )}
        </div>
        {isAuthenticated && <div className="p-4 pt-2 flex-none border-t border-white/10 bg-slate-900/90"><button onClick={handleSave} className="w-full bg-gradient-to-r from-yellow-600 to-yellow-500 hover:from-yellow-500 hover:to-yellow-400 text-black font-bold py-2.5 rounded-xl shadow-lg flex items-center justify-center transition-transform active:scale-95"><Save className="w-4 h-4 mr-2" /> 儲存並套用</button></div>}
      </div>
    </div>
  );
};

